# /etc/pam.d/common-auth - authentication settings common to all services
# Managed by Ansible - do not edit manually
#
# PAM stack: authentik (via pam_exec) -> local (pam_unix) -> deny
# If pam_exec succeeds (authentik auth), skip 2 lines to pam_permit.
# If pam_exec fails, try pam_unix (local password).
# If pam_unix succeeds, skip 1 line to pam_permit.
# If both fail, pam_deny rejects the auth.

auth [success=2 default=ignore] pam_exec.so expose_authtok quiet /opt/authentik-pam-auth.py
auth [success=1 default=ignore] pam_unix.so try_first_pass
auth requisite                  pam_deny.so
auth required                   pam_permit.so
auth optional                   pam_cap.so
