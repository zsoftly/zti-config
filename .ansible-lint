---
# Ansible-lint configuration for zti-config

profile: production

# Exclude paths
exclude_paths:
  - .venv/
  - venv/
  - .git/
  - .github/
  - collections/ansible_collections/
  - galaxy_collections/
  - '**/*.md'

# Skip specific rules
skip_list:
  - role-name  # Allow flexible role naming
  - galaxy[no-changelog]  # Not publishing to Galaxy yet
  - fqcn[action-core]  # Allow short module names for readability
  - fqcn[canonical]  # Allow ansible.builtin over ansible.posix for common modules
  - name[casing]  # Allow flexible task naming
  - var-naming[no-role-prefix]  # Roles use short variable names for readability
  - schema[tasks]  # Playbooks in non-standard paths get misdetected as tasks
  - internal-error  # CI cannot decrypt vault files for syntax-check

# Enable optional rules
enable_list:
  - no-same-owner  # Security: avoid setting same owner
  - yaml  # YAML syntax checking

# Warning vs Error
warn_list:
  - experimental
  - ignore-errors
  - no-handler
  - command-instead-of-module
  - command-instead-of-shell
  - no-changed-when
  - risky-shell-pipe
  - package-latest
  - jinja[spacing]
  - parser-error

# Kind mapping
kinds:
  - playbook: "**/playbooks/*.yml"
  - playbook: "**/playbooks/*.yaml"
  - tasks: "**/tasks/*.yml"
  - tasks: "**/tasks/*.yaml"
  - vars: "**/vars/*.yml"
  - vars: "**/vars/*.yaml"
  - defaults: "**/defaults/*.yml"
  - defaults: "**/defaults/*.yaml"
  - handlers: "**/handlers/*.yml"
  - handlers: "**/handlers/*.yaml"

# Mock modules
mock_modules:
  - docker_compose

# Mock roles
mock_roles:
  - wazuh_agent
  - system_updates
  - firmware_updates
  - otel_collector
  - 15_ssh_password_flow
  - 17_endpoint_agent
  - 18_endpoint_pam_exec
  - ssh_hardening
